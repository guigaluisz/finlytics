NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://finlytics:finlytics@localhost:5432/finlytics?schema=public
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
AWS_REGION=us-east-1
S3_BUCKET=finlytics-reports
THROTTLE_TTL=60
THROTTLE_LIMIT=100
JOBS_ENABLED=true
APP_RESET_URL=finlytics://redefinir-senha
MAIL_FROM=Finlytics <no-reply@finlytics.app>
# SMTP opcional — sem isso, e-mails são logados no console (dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
