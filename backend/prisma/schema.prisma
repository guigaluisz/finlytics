// Finlytics — Prisma schema (PostgreSQL)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  income
  expense
}

enum CategoryType {
  income
  expense
  both
}

enum AssetType {
  cdb
  lci
  lca
  tesouro
  fii
  stock
  etf
  intl
}

enum GoalStatus {
  active
  completed
  canceled
}

enum SubscriptionPlan {
  free
  premium_monthly
  premium_annual
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
  expired
}

enum AlertType {
  budget
  invoice
  goal
  system
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @db.VarChar(50)
  lastName       String?  @map("last_name") @db.VarChar(50)
  email          String   @unique @db.VarChar(160)
  passwordHash   String   @map("password_hash")
  phone          String?  @db.VarChar(20)
  avatarUrl      String?  @map("avatar_url")
  locale         String   @default("pt-BR") @db.VarChar(10)
  emailVerified  Boolean  @default(false) @map("email_verified")
  mfaEnabled     Boolean  @default(false) @map("mfa_enabled")
  mfaSecret      String?  @map("mfa_secret")
  onboardingGoal String?  @map("onboarding_goal") @db.VarChar(30)
  incomeRange    String?  @map("income_range") @db.VarChar(30)
  riskProfile    String?  @map("risk_profile") @db.VarChar(20)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  accounts       Account[]
  categories     Category[]
  transactions   Transaction[]
  creditCards    CreditCard[]
  budgets        Budget[]
  goals          FinancialGoal[]
  investments    Investment[]
  snapshots      NetWorthSnapshot[]
  alerts         Alert[]
  subscription   Subscription?
  refreshTokens  RefreshToken[]
  passwordResets PasswordResetToken[]
  auditLogs      AuditLog[]

  @@map("users")
}

model Account {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String   @db.VarChar(60)
  type      String   @db.VarChar(20) // checking | savings | wallet
  balance   Decimal  @default(0) @db.Decimal(14, 2)
  currency  String   @default("BRL") @db.VarChar(3)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@map("accounts")
}

model Category {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @map("user_id") @db.Uuid
  name      String       @db.VarChar(60)
  type      CategoryType @default(expense)
  color     String       @default("#6B7280") @db.VarChar(9)
  icon      String       @default("tag") @db.VarChar(40)
  isDefault Boolean      @default(false) @map("is_default")
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz
  deletedAt DateTime?    @map("deleted_at") @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@unique([userId, name])
  @@index([userId])
  @@map("categories")
}

model Transaction {
  id           String          @id @default(uuid()) @db.Uuid
  userId       String          @map("user_id") @db.Uuid
  categoryId   String?         @map("category_id") @db.Uuid
  accountId    String?         @map("account_id") @db.Uuid
  creditCardId String?         @map("credit_card_id") @db.Uuid
  type         TransactionType
  value        Decimal         @db.Decimal(14, 2)
  description  String?         @db.VarChar(255)
  date         DateTime        @db.Date
  recurrence   String?         @db.VarChar(20) // none|monthly|weekly|yearly
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime?       @map("deleted_at") @db.Timestamptz

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  account    Account?    @relation(fields: [accountId], references: [id], onDelete: SetNull)
  creditCard CreditCard? @relation(fields: [creditCardId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([userId, categoryId, date])
  @@index([userId, type, date])
  @@map("transactions")
}

model CreditCard {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  bank        String   @db.VarChar(60)
  brand       String   @db.VarChar(30)
  creditLimit Decimal  @map("credit_limit") @db.Decimal(14, 2)
  closingDay  Int      @map("closing_day") @db.SmallInt
  dueDay      Int      @map("due_day") @db.SmallInt
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@map("credit_cards")
}

model Budget {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  categoryId   String   @map("category_id") @db.Uuid
  monthlyLimit Decimal  @map("monthly_limit") @db.Decimal(14, 2)
  month        Int      @db.SmallInt
  year         Int      @db.SmallInt
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, month, year])
  @@index([userId])
  @@map("budgets")
}

model FinancialGoal {
  id            String     @id @default(uuid()) @db.Uuid
  userId        String     @map("user_id") @db.Uuid
  title         String     @db.VarChar(80)
  targetAmount  Decimal    @map("target_amount") @db.Decimal(14, 2)
  currentAmount Decimal    @default(0) @map("current_amount") @db.Decimal(14, 2)
  targetDate    DateTime   @map("target_date") @db.Date
  status        GoalStatus @default(active)
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions GoalContribution[]

  @@index([userId])
  @@map("financial_goals")
}

model GoalContribution {
  id        String   @id @default(uuid()) @db.Uuid
  goalId    String   @map("goal_id") @db.Uuid
  amount    Decimal  @db.Decimal(14, 2)
  date      DateTime @db.Date
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  goal FinancialGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@map("goal_contributions")
}

model Investment {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  assetType    AssetType @map("asset_type")
  ticker       String    @db.VarChar(20)
  quantity     Decimal   @db.Decimal(18, 6)
  averagePrice Decimal   @map("average_price") @db.Decimal(18, 6)
  currentPrice Decimal?  @map("current_price") @db.Decimal(18, 6)
  currency     String    @default("BRL") @db.VarChar(3)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, assetType])
  @@map("investments")
}

model NetWorthSnapshot {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  snapshotMonth DateTime @map("snapshot_month") @db.Date
  assets        Decimal  @db.Decimal(16, 2)
  liabilities   Decimal  @db.Decimal(16, 2)
  netWorth      Decimal  @map("net_worth") @db.Decimal(16, 2)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, snapshotMonth])
  @@index([userId])
  @@map("net_worth_snapshots")
}

model Alert {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  type      AlertType
  title     String    @db.VarChar(120)
  message   String    @db.VarChar(300)
  read      Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("alerts")
}

model Subscription {
  id             String             @id @default(uuid()) @db.Uuid
  userId         String             @unique @map("user_id") @db.Uuid
  plan           SubscriptionPlan   @default(free)
  status         SubscriptionStatus @default(active)
  provider       String?            @db.VarChar(20) // apple | google | stripe
  externalId     String?            @map("external_id")
  expirationDate DateTime?          @map("expiration_date") @db.Timestamptz
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  device    String?   @db.VarChar(120)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@map("password_reset_tokens")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar(60)
  entity    String?  @db.VarChar(60)
  entityId  String?  @map("entity_id") @db.VarChar(60)
  metadata  Json?
  ip        String?  @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}
