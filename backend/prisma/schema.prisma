// Finlytics — schema Prisma (PostgreSQL) — nomes em português
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  receita
  despesa
}

enum CategoryType {
  receita
  despesa
  ambos
}

enum AssetType {
  cdb
  lci
  lca
  tesouro
  fii
  acao
  etf
  internacional
}

enum GoalStatus {
  ativa
  concluida
  cancelada
}

enum SubscriptionPlan {
  gratuito
  premium_mensal
  premium_anual
}

enum SubscriptionStatus {
  ativa
  teste
  atrasada
  cancelada
  expirada
}

enum AlertType {
  orcamento
  fatura
  meta
  sistema
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  nome            String    @db.VarChar(50)
  sobrenome       String?   @db.VarChar(50)
  email           String    @unique @db.VarChar(160)
  senhaHash       String    @map("senha_hash")
  telefone        String?   @db.VarChar(20)
  fotoUrl         String?   @map("foto_url")
  idioma          String    @default("pt-BR") @db.VarChar(10)
  emailVerificado Boolean   @default(false) @map("email_verificado")
  mfaAtivo        Boolean   @default(false) @map("mfa_ativo")
  mfaSegredo      String?   @map("mfa_segredo")
  objetivo        String?   @db.VarChar(30)
  faixaRenda      String?   @map("faixa_renda") @db.VarChar(30)
  perfilRisco     String?   @map("perfil_risco") @db.VarChar(20)
  criadoEm        DateTime  @default(now()) @map("criado_em") @db.Timestamptz
  atualizadoEm    DateTime  @updatedAt @map("atualizado_em") @db.Timestamptz
  excluidoEm      DateTime? @map("excluido_em") @db.Timestamptz

  contas            Account[]
  categorias        Category[]
  transacoes        Transaction[]
  cartoes           CreditCard[]
  orcamentos        Budget[]
  metas             FinancialGoal[]
  investimentos     Investment[]
  snapshots         NetWorthSnapshot[]
  alertas           Alert[]
  assinatura        Subscription?
  tokensAtualizacao RefreshToken[]
  redefinicoesSenha PasswordResetToken[]
  logsAuditoria     AuditLog[]

  @@map("usuarios")
}

model Account {
  id        String   @id @default(uuid()) @db.Uuid
  usuarioId String   @map("usuario_id") @db.Uuid
  nome      String   @db.VarChar(60)
  tipo      String   @db.VarChar(20)
  saldo     Decimal  @default(0) @db.Decimal(14, 2)
  moeda     String   @default("BRL") @db.VarChar(3)
  criadoEm  DateTime @default(now()) @map("criado_em") @db.Timestamptz

  usuario    User          @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  transacoes Transaction[]

  @@index([usuarioId])
  @@map("contas")
}

model Category {
  id        String       @id @default(uuid()) @db.Uuid
  usuarioId String       @map("usuario_id") @db.Uuid
  nome      String       @db.VarChar(60)
  tipo      CategoryType @default(despesa)
  cor       String       @default("#6B7280") @db.VarChar(9)
  icone     String       @default("tag") @db.VarChar(40)
  padrao    Boolean      @default(false)
  criadoEm  DateTime     @default(now()) @map("criado_em") @db.Timestamptz
  excluidoEm DateTime?   @map("excluido_em") @db.Timestamptz

  usuario    User          @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  transacoes Transaction[]
  orcamentos Budget[]

  @@unique([usuarioId, nome])
  @@index([usuarioId])
  @@map("categorias")
}

model Transaction {
  id          String          @id @default(uuid()) @db.Uuid
  usuarioId   String          @map("usuario_id") @db.Uuid
  categoriaId String?         @map("categoria_id") @db.Uuid
  contaId     String?         @map("conta_id") @db.Uuid
  cartaoId    String?         @map("cartao_id") @db.Uuid
  tipo        TransactionType
  valor       Decimal         @db.Decimal(14, 2)
  descricao   String?         @db.VarChar(255)
  data        DateTime        @db.Date
  recorrencia String?         @db.VarChar(20)
  criadoEm    DateTime        @default(now()) @map("criado_em") @db.Timestamptz
  atualizadoEm DateTime       @updatedAt @map("atualizado_em") @db.Timestamptz
  excluidoEm  DateTime?       @map("excluido_em") @db.Timestamptz

  usuario   User        @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  categoria Category?   @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  conta     Account?    @relation(fields: [contaId], references: [id], onDelete: SetNull)
  cartao    CreditCard? @relation(fields: [cartaoId], references: [id], onDelete: SetNull)

  @@index([usuarioId, data])
  @@index([usuarioId, categoriaId, data])
  @@index([usuarioId, tipo, data])
  @@map("transacoes")
}

model CreditCard {
  id            String    @id @default(uuid()) @db.Uuid
  usuarioId     String    @map("usuario_id") @db.Uuid
  banco         String    @db.VarChar(60)
  bandeira      String    @db.VarChar(30)
  limite        Decimal   @db.Decimal(14, 2)
  diaFechamento Int       @map("dia_fechamento") @db.SmallInt
  diaVencimento Int       @map("dia_vencimento") @db.SmallInt
  criadoEm      DateTime  @default(now()) @map("criado_em") @db.Timestamptz
  excluidoEm    DateTime? @map("excluido_em") @db.Timestamptz

  usuario    User          @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  transacoes Transaction[]

  @@index([usuarioId])
  @@map("cartoes")
}

model Budget {
  id           String   @id @default(uuid()) @db.Uuid
  usuarioId    String   @map("usuario_id") @db.Uuid
  categoriaId  String   @map("categoria_id") @db.Uuid
  limiteMensal Decimal  @map("limite_mensal") @db.Decimal(14, 2)
  mes          Int      @db.SmallInt
  ano          Int      @db.SmallInt
  criadoEm     DateTime @default(now()) @map("criado_em") @db.Timestamptz

  usuario   User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  categoria Category @relation(fields: [categoriaId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, categoriaId, mes, ano])
  @@index([usuarioId])
  @@map("orcamentos")
}

model FinancialGoal {
  id           String     @id @default(uuid()) @db.Uuid
  usuarioId    String     @map("usuario_id") @db.Uuid
  titulo       String     @db.VarChar(80)
  valorAlvo    Decimal    @map("valor_alvo") @db.Decimal(14, 2)
  valorAtual   Decimal    @default(0) @map("valor_atual") @db.Decimal(14, 2)
  dataAlvo     DateTime   @map("data_alvo") @db.Date
  status       GoalStatus @default(ativa)
  criadoEm     DateTime   @default(now()) @map("criado_em") @db.Timestamptz
  atualizadoEm DateTime   @updatedAt @map("atualizado_em") @db.Timestamptz

  usuario User               @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  aportes GoalContribution[]

  @@index([usuarioId])
  @@map("metas")
}

model GoalContribution {
  id       String   @id @default(uuid()) @db.Uuid
  metaId   String   @map("meta_id") @db.Uuid
  valor    Decimal  @db.Decimal(14, 2)
  data     DateTime @db.Date
  criadoEm DateTime @default(now()) @map("criado_em") @db.Timestamptz

  meta FinancialGoal @relation(fields: [metaId], references: [id], onDelete: Cascade)

  @@index([metaId])
  @@map("aportes")
}

model Investment {
  id           String    @id @default(uuid()) @db.Uuid
  usuarioId    String    @map("usuario_id") @db.Uuid
  tipoAtivo    AssetType @map("tipo_ativo")
  ticker       String    @db.VarChar(20)
  quantidade   Decimal   @db.Decimal(18, 6)
  precoMedio   Decimal   @map("preco_medio") @db.Decimal(18, 6)
  precoAtual   Decimal?  @map("preco_atual") @db.Decimal(18, 6)
  moeda        String    @default("BRL") @db.VarChar(3)
  criadoEm     DateTime  @default(now()) @map("criado_em") @db.Timestamptz
  atualizadoEm DateTime  @updatedAt @map("atualizado_em") @db.Timestamptz

  usuario User @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([usuarioId, tipoAtivo])
  @@map("investimentos")
}

model NetWorthSnapshot {
  id                String   @id @default(uuid()) @db.Uuid
  usuarioId         String   @map("usuario_id") @db.Uuid
  mesReferencia     DateTime @map("mes_referencia") @db.Date
  ativos            Decimal  @db.Decimal(16, 2)
  passivos          Decimal  @db.Decimal(16, 2)
  patrimonioLiquido Decimal  @map("patrimonio_liquido") @db.Decimal(16, 2)
  criadoEm          DateTime @default(now()) @map("criado_em") @db.Timestamptz

  usuario User @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, mesReferencia])
  @@index([usuarioId])
  @@map("snapshots_patrimonio")
}

model Alert {
  id        String    @id @default(uuid()) @db.Uuid
  usuarioId String    @map("usuario_id") @db.Uuid
  tipo      AlertType
  titulo    String    @db.VarChar(120)
  mensagem  String    @db.VarChar(300)
  lida      Boolean   @default(false)
  criadoEm  DateTime  @default(now()) @map("criado_em") @db.Timestamptz

  usuario User @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, lida])
  @@map("alertas")
}

model Subscription {
  id            String             @id @default(uuid()) @db.Uuid
  usuarioId     String             @unique @map("usuario_id") @db.Uuid
  plano         SubscriptionPlan   @default(gratuito)
  status        SubscriptionStatus @default(ativa)
  provedor      String?            @db.VarChar(20)
  idExterno     String?            @map("id_externo")
  dataExpiracao DateTime?          @map("data_expiracao") @db.Timestamptz
  criadoEm      DateTime           @default(now()) @map("criado_em") @db.Timestamptz
  atualizadoEm  DateTime           @updatedAt @map("atualizado_em") @db.Timestamptz

  usuario User @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("assinaturas")
}

model RefreshToken {
  id          String    @id @default(uuid()) @db.Uuid
  usuarioId   String    @map("usuario_id") @db.Uuid
  tokenHash   String    @map("token_hash")
  dispositivo String?   @db.VarChar(120)
  expiraEm    DateTime  @map("expira_em") @db.Timestamptz
  revogadoEm  DateTime? @map("revogado_em") @db.Timestamptz
  criadoEm    DateTime  @default(now()) @map("criado_em") @db.Timestamptz

  usuario User @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([tokenHash])
  @@map("tokens_atualizacao")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  usuarioId String    @map("usuario_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiraEm  DateTime  @map("expira_em") @db.Timestamptz
  usadoEm   DateTime? @map("usado_em") @db.Timestamptz
  criadoEm  DateTime  @default(now()) @map("criado_em") @db.Timestamptz

  usuario User @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@map("tokens_redefinicao_senha")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  usuarioId  String?  @map("usuario_id") @db.Uuid
  acao       String   @db.VarChar(60)
  entidade   String?  @db.VarChar(60)
  entidadeId String?  @map("entidade_id") @db.VarChar(60)
  metadados  Json?
  ip         String?  @db.VarChar(45)
  criadoEm   DateTime @default(now()) @map("criado_em") @db.Timestamptz

  usuario User? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([usuarioId])
  @@index([acao])
  @@map("logs_auditoria")
}
